# ============================================================
# Mini Beer Tracker — Env
# Naming: NUXT_<KEY> für runtimeConfig, NUXT_PUBLIC_<KEY> für
# runtimeConfig.public (siehe nuxt.config.ts).
# Prisma's DATABASE_URL ist Prisma-Konvention (kein NUXT_-Prefix).
# ============================================================

# --- Database (Prisma / SQLite) ---
DATABASE_URL="file:./dev.db"

# --- Session (nuxt-auth-utils) ---
# Pflicht. Name ist fest. Min. 32 Zeichen. Generate:
#   bun -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
NUXT_SESSION_PASSWORD="change-me-please-min-32-chars-long-secret-value"

# --- Runtime Config Overrides (optional) ---
# runtimeConfig.nominatimUserAgent  (server-only — Nominatim Usage Policy)
NUXT_NOMINATIM_USER_AGENT="MiniBeerTracker/0.1 (you@example.com)"
